---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center py-20">
    <p class="text-sky-400 text-sm font-medium uppercase tracking-widest mb-4">Error 404</p>
    <h1 class="text-6xl md:text-8xl font-bold text-slate-200 dark:text-slate-700 mb-6 select-none">
      404
    </h1>
    <h2 class="text-xl md:text-2xl font-semibold text-slate-800 dark:text-slate-200 mb-4">
      Page not found
    </h2>
    <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-md">
      Looks like this route doesn't exist. Maybe it was moved, deleted, or you typed the URL incorrectly.
    </p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a
        href="/"
        class="px-5 py-2.5 bg-sky-500 hover:bg-sky-600 text-white rounded-md transition-colors duration-200 font-medium text-sm"
      >
        Go Home
      </a>
      <a
        href="/blog"
        class="px-5 py-2.5 border border-slate-300 dark:border-slate-700 hover:border-sky-400 dark:hover:border-sky-400 text-slate-700 dark:text-slate-300 rounded-md transition-colors duration-200 font-medium text-sm"
      >
        Read Blog
      </a>
    </div>
  </div>
</Layout>
