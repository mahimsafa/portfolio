---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="mb-4 text-sm font-medium uppercase tracking-widest text-sky-400">Error 404</p>
    <h1 class="mb-6 select-none text-6xl font-bold text-slate-200 dark:text-slate-700 md:text-8xl">
      404
    </h1>
    <h2 class="mb-4 text-xl font-semibold text-slate-800 dark:text-slate-200 md:text-2xl">
      Page not found
    </h2>
    <p class="mb-8 max-w-md text-slate-500 dark:text-slate-400">
      Looks like this route doesn't exist. Maybe it was moved, deleted, or you typed the URL
      incorrectly.
    </p>
    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href="/"
        class="rounded-md bg-sky-500 px-5 py-2.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-sky-600"
      >
        Go Home
      </a>
      <a
        href="/blog"
        class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition-colors duration-200 hover:border-sky-400 dark:border-slate-700 dark:text-slate-300 dark:hover:border-sky-400"
      >
        Read Blog
      </a>
    </div>
  </div>
</Layout>
