---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

interface ContactLink {
  platform: string;
  handle: string;
  href: string;
  icon: string;
  description: string;
  isExternal: boolean;
}

const contactLinks: ContactLink[] = [
  {
    platform: 'Email',
    handle: 'hello@mahimsafa.com',
    href: 'mailto:hello@mahimsafa.com',
    icon: 'bi:envelope-fill',
    description: 'Best for project inquiries',
    isExternal: false,
  },
  {
    platform: 'LinkedIn',
    handle: 'linkedin.com/in/mahimsafa',
    href: 'https://www.linkedin.com/in/mahimsafa/',
    icon: 'bi:linkedin',
    description: 'Connect professionally',
    isExternal: true,
  },
  {
    platform: 'GitHub',
    handle: 'github.com/mahimsafa',
    href: 'https://github.com/mahimsafa',
    icon: 'bi:github',
    description: 'See my open-source work',
    isExternal: true,
  },
  {
    platform: 'Twitter / X',
    handle: '@mahim_safa',
    href: 'https://twitter.com/mahim_safa',
    icon: 'bi:twitter-x',
    description: 'Thoughts and updates',
    isExternal: true,
  },
  {
    platform: 'Fiverr',
    handle: 'fiverr.com/mahimsafa',
    href: 'https://www.fiverr.com/mahimsafa',
    icon: 'bi:bag-fill',
    description: 'Hire me for freelance work',
    isExternal: true,
  },
];
---

<Layout
  title="Hire Me"
  description="Get in touch with Mahim Safa for AWS consulting, DevOps engineering, full-stack development, and AI integration projects."
>
  <section class="mx-auto my-12 flex w-full max-w-2xl flex-col items-start px-2">
    <!-- Heading -->
    <div class="mb-8">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-sky-400">
        // available for work
      </p>
      <h1 class="text-3xl font-bold leading-tight text-gray-900 dark:text-slate-100 sm:text-4xl">
        Let's Build Something<br />
        <span class="text-sky-400">Together</span>
      </h1>
    </div>

    <!-- Intro paragraph -->
    <p class="mb-10 max-w-prose text-base leading-relaxed text-gray-600 dark:text-slate-400">
      I'm currently available for freelance projects, consulting, and full-time opportunities.
      Whether you need a new product built from scratch, a codebase untangled, or a reliable
      engineer on your team — feel free to reach out through any of the channels below.
    </p>

    <!-- Contact cards grid -->
    <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            aria-label={`${link.platform}: ${link.handle}`}
            {...(link.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="group flex items-start gap-4 rounded-md border border-gray-200 bg-white p-5 transition-colors duration-200 hover:border-sky-400 dark:border-slate-700 dark:bg-slate-800"
          >
            <div class="mt-0.5 shrink-0">
              <Icon
                name={link.icon}
                class="h-6 w-6 text-gray-400 transition-colors duration-200 group-hover:text-sky-400 dark:text-slate-500"
              />
            </div>
            <div class="flex min-w-0 flex-col">
              <span class="mb-0.5 text-xs font-semibold uppercase tracking-widest text-sky-400">
                {link.platform}
              </span>
              <span class="truncate text-sm font-medium text-gray-900 dark:text-slate-200">
                {link.handle}
              </span>
              <span class="mt-0.5 text-xs text-gray-500 dark:text-slate-400">
                {link.description}
              </span>
            </div>
            {link.isExternal && (
              <Icon
                name="bi:arrow-up-right"
                class="ml-auto mt-0.5 h-4 w-4 shrink-0 text-gray-300 transition-colors duration-200 group-hover:text-sky-400 dark:text-slate-600"
              />
            )}
          </a>
        ))
      }
    </div>
  </section>
</Layout>
