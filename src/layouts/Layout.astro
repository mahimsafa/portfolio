---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import type { SEOProps } from '../types/index';
import MobileNav from '../components/MobileNav.astro';

interface Props extends SEOProps {
  canonicalUrl?: string | undefined;
}

const {
  title: rawTitle,
  description = 'AWS, DevOps, and full-stack developer specializing in cloud architecture, MERN stack, and AI systems.',
  image,
  type,
  publishedDate,
  tags,
  canonicalUrl,
} = Astro.props;

const title = rawTitle ? `${rawTitle} | Mahim Safa` : 'Mahim Safa';
---

<style is:global>
  /* ─── Keyframes ─────────────────────────────────────────────── */

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes gridPulse {
    0%, 100% { opacity: 0.18; }
    50%       { opacity: 0.32; }
  }

  @keyframes scanline {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }

  @keyframes glowDrift {
    0%   { transform: translate(0%, 0%); }
    33%  { transform: translate(30%, -20%); }
    66%  { transform: translate(-20%, 30%); }
    100% { transform: translate(0%, 0%); }
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @keyframes nameReveal {
    from { opacity: 0; transform: translateY(10px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0);    filter: blur(0); }
  }

  @keyframes titleSlide {
    from { opacity: 0; transform: translateX(-16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes dotPulseRing {
    0%   { transform: scale(1);   opacity: 0.8; }
    100% { transform: scale(2.4); opacity: 0; }
  }

  @keyframes neonFlicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { opacity: 1; }
    20%, 24%, 55% { opacity: 0.4; }
  }

  @keyframes underlineDraw {
    from { width: 0; }
    to   { width: 100%; }
  }

  @keyframes cardGlowIn {
    from { box-shadow: 0 0 0 0 rgba(56,189,248,0); }
    to   { box-shadow: 0 0 24px 2px rgba(56,189,248,0.18); }
  }

  /* ─── Scroll-reveal ──────────────────────────────────────────── */
  [data-animate] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .animate-fade-in {
    animation: fadeInUp 0.7s ease-out both;
  }

  /* ─── Section heading accent ─────────────────────────────────── */
  .section-heading {
    position: relative;
    display: inline-block;
  }
  .section-heading::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    height: 2px;
    background: #38bdf8;
    width: 0;
    border-radius: 2px;
    box-shadow: 0 0 8px #38bdf8;
  }
  .section-heading.is-visible::after {
    animation: underlineDraw 0.6s 0.3s ease-out forwards;
  }

  /* ─── Neon card glow on hover ────────────────────────────────── */
  .neon-card {
    transition: transform 0.2s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .neon-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 20px 2px rgba(56,189,248,0.15), 0 8px 32px rgba(0,0,0,0.4);
    border-color: rgba(56,189,248,0.5);
  }

  /* ─── Skill tag glitch on hover ──────────────────────────────── */
  .skill-tag {
    position: relative;
    transition: color 0.15s, border-color 0.15s, text-shadow 0.15s;
  }
  .skill-tag:hover {
    color: #38bdf8;
    border-color: #38bdf8;
    text-shadow: 0 0 8px rgba(56,189,248,0.7);
    animation: neonFlicker 0.4s ease-in-out;
  }

  /* ─── Focus rings ────────────────────────────────────────────── */
  :focus-visible {
    outline: 2px solid #38bdf8;
    outline-offset: 2px;
    box-shadow: 0 0 8px rgba(56,189,248,0.4);
  }

  /* ─── Text selection ─────────────────────────────────────────── */
  ::selection      { background-color: #38bdf8; color: #020617; }
  ::-moz-selection { background-color: #38bdf8; color: #020617; }

  /* ─── Scrollbar ──────────────────────────────────────────────── */
  ::-webkit-scrollbar       { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #38bdf8; border-radius: 2px; box-shadow: 0 0 6px #38bdf8; }
  ::-webkit-scrollbar-thumb:hover { background: #0ea5e9; }

  /* ─── Reduced motion ─────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    [data-animate]   { opacity: 1; transform: none; transition: none; }
    .animate-fade-in { animation: none; }
    .section-heading::after { animation: none; width: 100%; }
  }

  /* ─── Fonts ──────────────────────────────────────────────────── */
  @font-face {
    font-family: 'JetBrains Mono';
    src: url('/fonts/webfonts/JetBrainsMono-Regular.woff2') format('woff2');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'JetBrains Mono';
    src: url('/fonts/webfonts/JetBrainsMono-Medium.woff2') format('woff2');
    font-weight: 500; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'JetBrains Mono';
    src: url('/fonts/webfonts/JetBrainsMono-SemiBold.woff2') format('woff2');
    font-weight: 600; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'JetBrains Mono';
    src: url('/fonts/webfonts/JetBrainsMono-Bold.woff2') format('woff2');
    font-weight: 700; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'JetBrains Mono';
    src: url('/fonts/webfonts/JetBrainsMono-Italic.woff2') format('woff2');
    font-weight: 400; font-style: italic; font-display: swap;
  }
</style>

<!-- Force dark mode always -->
<html lang="en" class="dark scroll-smooth bg-slate-950 text-slate-200">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Always dark — remove any stored light preference
      localStorage.setItem('theme', 'dark');
      document.documentElement.classList.add('dark');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <SEO
      title={rawTitle}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      tags={tags}
      canonicalUrl={canonicalUrl}
    />
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="min-h-screen w-screen overflow-x-hidden bg-slate-950">

    <!-- ── Neon grid background ───────────────────────────────── -->
    <div class="neon-bg" aria-hidden="true">
      <!-- CSS grid lines -->
      <div class="grid-lines"></div>
      <!-- Floating radial glow -->
      <div class="glow-orb"></div>
      <!-- Subtle scanline sweep -->
      <div class="scanline"></div>
    </div>

    <style>
      .neon-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }

      /* Perspective grid made of CSS linear-gradient lines */
      .grid-lines {
        position: absolute;
        inset: -10%;
        background-image:
          linear-gradient(rgba(56,189,248,0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(56,189,248,0.07) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridPulse 6s ease-in-out infinite;
      }

      /* Accent dots at grid intersections */
      .grid-lines::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(56,189,248,0.15) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Drifting radial glow */
      .glow-orb {
        position: absolute;
        width: 70vw;
        height: 70vw;
        max-width: 800px;
        max-height: 800px;
        top: -20%;
        left: -10%;
        background: radial-gradient(circle, rgba(56,189,248,0.07) 0%, transparent 65%);
        animation: glowDrift 18s ease-in-out infinite;
        will-change: transform;
      }

      /* Second glow — bottom right, complementary */
      .glow-orb::after {
        content: '';
        position: absolute;
        width: 60vw;
        height: 60vw;
        max-width: 600px;
        max-height: 600px;
        bottom: -60%;
        right: -20%;
        left: auto;
        top: auto;
        background: radial-gradient(circle, rgba(14,165,233,0.06) 0%, transparent 65%);
        animation: glowDrift 22s ease-in-out infinite reverse;
      }

      /* Fast translucent scanline sweep */
      .scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(56,189,248,0.12), transparent);
        animation: scanline 8s linear infinite;
        will-change: transform;
      }
    </style>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-sky-500 focus:px-4 focus:py-2 focus:font-medium focus:text-white"
    >
      Skip to main content
    </a>

    <Navbar />

    <div
      id="main-content"
      class="relative z-10 -mt-16 flex min-h-full flex-col space-y-10 px-6 pb-20 pt-16 sm:px-10 lg:px-16 lg:pb-10"
    >
      <slot />
    </div>

    <Footer />

    <script>
      // Scroll-reveal observer
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

      // Also animate section headings
      document.querySelectorAll('.section-heading').forEach((el) => observer.observe(el));
    </script>

    <MobileNav />
  </body>
</html>
