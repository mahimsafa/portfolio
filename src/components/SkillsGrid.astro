---
import { skillCategories } from '../content/data';
---

<section id="skills" class="w-full py-16" data-animate>
  <h2 class="section-heading mb-12 text-center text-2xl font-bold text-slate-100 sm:text-3xl">
    Skills
  </h2>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {
      skillCategories.map((category) => (
        <div class="neon-card rounded-lg border border-slate-700 bg-slate-900/60 p-5">
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-sky-400">
            {category.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="skill-tag cursor-default rounded border border-slate-700 bg-slate-800 px-2.5 py-1 text-xs font-medium text-slate-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
