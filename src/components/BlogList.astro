---
import { getCollection } from 'astro:content';
import { format } from 'date-fns';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<section id="blog" class="w-full py-16" data-animate>
  <h2 class="section-heading mb-4 text-center text-2xl font-bold text-slate-100 sm:text-3xl">
    Latest Articles
  </h2>
  <p class="mb-12 text-center text-sm text-slate-400">
    Thoughts on development, cloud, and security
  </p>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {
      posts.map((post) => (
        <a
          href={`/article/${post.slug}`}
          class="neon-card group flex flex-col rounded-lg border border-slate-700 bg-slate-900/60 p-5"
        >
          <h3 class="mb-2 font-medium text-slate-100 transition-colors duration-150 group-hover:text-sky-400">
            {post.data.title}
          </h3>
          <div class="mb-3 flex flex-wrap gap-1">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="rounded bg-slate-800 px-2 py-0.5 text-xs text-slate-400">
                {tag}
              </span>
            ))}
          </div>
          <p class="mt-auto text-xs text-slate-500">
            {format(post.data.date, 'MMM d, yyyy')}
          </p>
        </a>
      ))
    }
  </div>

  <div class="mt-8 text-center">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm font-medium text-sky-400 transition-colors duration-150 hover:text-sky-300"
    >
      View all articles
      <span>&rarr;</span>
    </a>
  </div>
</section>
