---
import { format } from 'date-fns';

let date = format(new Date(Astro.props.date), 'PPPP, p');
---

<div
  class="flex flex-col items-center space-x-2 border shadow-sm transition-transform duration-200 hover:-translate-y-1 dark:border-slate-700 dark:bg-slate-800 md:flex-row md:p-2"
>
  <a
    href={`/article/${Astro.props.slug}`}
    class="flex h-full w-full items-center justify-center md:block"
  >
    <img
      src={Astro.props.img}
      alt={Astro.props.heading}
      width={250}
      height={167}
      loading="lazy"
      class="cursor-pointer rounded"
    />
  </a>
  <div class="mt-2 flex flex-col space-y-2 md:mt-0 md:block">
    <h1
      class="cursor-pointer text-2xl font-semibold transition-colors duration-150 ease-in-out hover:text-sky-400 dark:text-slate-200"
    >
      <a href={`/article/${Astro.props.slug}`}>{Astro.props.heading}</a>
    </h1>
    <h4 class="text-sm text-gray-500 dark:text-slate-400">{date}</h4>
    <p class="dark:text-slate-300">
      {Astro.props.description}
    </p>
  </div>
</div>
