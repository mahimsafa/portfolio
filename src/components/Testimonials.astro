---
import CardV3 from "./CardV3.astro";
import { review } from "../content/data.ts";
import type { Review } from "../types/index";
---

<section class="w-full flex flex-col justify-center" id="contact">
  <h1 class="text-sky-400 text-3xl font-semibold mx-auto my-10">
    Testimonials
  </h1>
  <div
    class="w-full p-3 flex flex-col justify-center overflow-x-hidden my-10"
  >
    <div class="flex flex-col md:flex-row md:space-x-7 space-y-5 md:space-y-0 justify-center items-center">
      {
        review.map((item: Review) => (
          <CardV3
            gender={item.gender}
            name={item.name}
            review={item.body}
            ref={item.ref}
            img={item.img}
            role={item.role}
            company={item.company}
          />
        ))
      }
    </div>
  </div>
</section>
