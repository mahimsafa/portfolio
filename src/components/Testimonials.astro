---
import CardV3 from './CardV3.astro';
import { review } from '../content/data.ts';
import type { Review } from '../types/index';
---

<section class="flex w-full flex-col justify-center" id="contact" data-animate>
  <h1 class="mx-auto my-10 text-3xl font-semibold text-sky-400">Testimonials</h1>
  <div class="my-10 flex w-full flex-col justify-center overflow-x-hidden p-3">
    <div
      class="flex flex-col items-center justify-center space-y-5 md:flex-row md:space-x-7 md:space-y-0"
    >
      {
        review.map((item: Review) => (
          <CardV3
            gender={item.gender}
            name={item.name}
            review={item.body}
            ref={item.ref}
            img={item.img}
            role={item.role}
            company={item.company}
          />
        ))
      }
    </div>
  </div>
</section>
